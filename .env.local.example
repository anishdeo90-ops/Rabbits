# Copy this file to .env.local and fill in your Supabase credentials.
# Get these from Supabase Dashboard -> Project Settings -> API.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: AI resume parsing fallback key.
# The app can also use user/org AI settings from the database.
ANTHROPIC_API_KEY=

# Site4People inbound boost-job webhook.
SITE4PEOPLE_API_KEY=

# Optional: URL supplied by Site4People where this ATS should POST candidates back.
SITE4PEOPLE_CANDIDATE_CALLBACK_URL=
